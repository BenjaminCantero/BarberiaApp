# Base de datos
DATABASE_URL="postgresql://usuario:password@localhost:5432/barber_booking"

# JWT
JWT_ACCESS_SECRET="cambia_este_secreto_access_muy_seguro"
JWT_REFRESH_SECRET="cambia_este_secreto_refresh_muy_seguro"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Servidor
PORT=3000
NODE_ENV=development

# CORS
FRONTEND_URL="http://localhost:5173"

# Datos del negocio (usados en emails)
SHOP_NAME="Mi Barbería"
SHOP_TIMEZONE="America/Argentina/Buenos_Aires"

# Email / SMTP (opcional)
# Si SMTP_HOST y SMTP_USER no están definidos, los emails se registran en
# consola en vez de enviarse (modo desarrollo). Para producción configurá un
# proveedor (Resend, SendGrid, Mailgun, Gmail SMTP, etc.).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@barberia.app"
